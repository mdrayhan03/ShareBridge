<Header>:
    orientation: 'horizontal'
    md_bg_color: 0.12, 0.12, 0.12, 1
    adaptive_height: True
    pos_hint: {'top': 1}
    padding: "10dp"

    MDWidget:

    MDIconButton:
        icon: 'account-group'
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        on_release: app.root.get_screen('InboxPage').ids.right_drawer.set_state("toggle")

    MDIconButton:
        icon: 'cog'
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        on_release: app.root.current = 'SettingsPage'