<SettingsSidebar>:
    orientation: 'vertical'
    size_hint_x: 0.3
    md_bg_color: 0.1, 0.1, 0.1, 1
    padding: "12dp"
    spacing: "12dp"
    
    # Back Button
    MDBoxLayout:
        adaptive_height: True
        MDIconButton:
            icon: "arrow-left"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            on_release: app.root.current = "InboxPage"
        MDLabel:
            text: "Settings"
            bold: True
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            pos_hint: {"center_y": .5}
            
    MDDivider:
    
    MDScrollView:
        MDList:
            MDListItem:
                on_release: app.root.get_screen('SettingsPage').show_profile_settings()
                MDListItemLeadingIcon:
                    icon: "account-cog"
                MDListItemHeadlineText:
                    text: "Profile Setting"
                    
    MDWidget:
